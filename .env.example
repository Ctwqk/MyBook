# ========================================
# MyBook LLM Agent 配置
# ========================================

# ==========================
# 全局 LLM Provider 设置
# ==========================
# 可选值: mock | openai | anthropic | ollama | siliconflow
LLM_PROVIDER=openai

# ==========================
# OpenAI 兼容 API
# ==========================
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=https://api.minimaxi.com/v1

# OpenAI 模型配置
OPENAI_MODEL=MiniMax-M2.7
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=128000

# ==========================
# Anthropic Claude
# ==========================
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_MAX_TOKENS=4096

# ==========================
# Ollama (本地模型)
# ==========================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=4096

# ==========================
# SiliconFlow (国内 API)
# ==========================
SILICONFLOW_API_KEY=your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_TEMPERATURE=0.7
SILICONFLOW_MAX_TOKENS=4096

# ==========================
# DeepSeek
# ==========================
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=4096

# ==========================
# 智谱 AI (GLM)
# ==========================
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4
ZHIPU_TEMPERATURE=0.7
ZHIPU_MAX_TOKENS=4096

# ==========================
# 各模块默认模型
# ==========================
# Planner 模块 - 负责规划、设定生成
PLANNER_MODEL=MiniMax-M2.7

# Writer 模块 - 负责正文生成
WRITER_MODEL=MiniMax-M2.7

# Reviewer 模块 - 负责审查、评分
REVIEWER_MODEL=MiniMax-M2.7

# ==========================
# 生成参数默认值
# ==========================
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
DEFAULT_TOP_P=0.9

# ==========================
# 数据库
# ==========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mybook

# ==========================
# 应用设置
# ==========================
APP_ENV=development
LOG_LEVEL=INFO
